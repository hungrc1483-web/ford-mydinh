    font-size: 15px;
    transition: 0.2s;
  }
  input:focus, select:focus {
    border-color: #0084ff;
    box-shadow: 0 0 0 3px rgba(0,132,255,0.15);
    outline: none;
  }
  button {
    width: 100%;
    background: linear-gradient(135deg, #0084ff, #00a2ff);
    color: white;
    padding: 15px;
    border: none;
    border-radius: 12px;
    font-size: 17px;
    cursor: pointer;
    font-weight: 600;
    transition: 0.2s;
  }
  button:hover {
