<script>
document.addEventListener('click', function(event) {
    // 1. Tìm phần tử được click hoặc phần tử cha gần nhất của nó
    var target = event.target;
    
    // 2. Kiểm tra xem nút được click có thuộc tính onclick chứa "sendLeadData" không
    // và xem nó có nằm bên trong khung chat id "car-chat-popup" hay không
    if (target && target.getAttribute('onclick') && target.getAttribute('onclick').includes('sendLeadData')) {
        var chatPopup = target.closest('#car-chat-popup');
        
        if (chatPopup) {
            // Kiểm tra xem form nhập sđt có dữ liệu hay không (tránh click ảo khi chưa nhập gì)
            var phoneInput = chatPopup.querySelector('.form-sdt');
            var phoneValue = phoneInput ? phoneInput.value.trim() : '';
            
            // Nếu form có nhập dữ liệu (độ dài > 0), tiến hành gửi dữ liệu lên Google
            if (phoneValue.length > 0) {
                
                // Đẩy sự kiện vào dataLayer cho Google Tag Manager (nếu dùng GTM)
                window.dataLayer = window.dataLayer || [];
                window.dataLayer.push({
                    'event': 'chat_lead_success',
                    'chat_id': 'car-chat-popup'
                });
                
                // Gửi trực tiếp về GA4 (Mã đo lường: G-N88V2GRCQ6) đề phòng bạn không dùng GTM
                if (typeof gtag === 'function') {
                    gtag('event', 'generate_lead_chat', {
                        'send_to': 'G-N88V2GRCQ6',
                        'chat_id': 'car-chat-popup'
                    });
                }
                
                console.log('Đã ghi nhận chuyển đổi chat thành công!');
            }
        }
    }
}, true);
</script><script type="text/javascript" src="/frontend/js/jquery.min.js"></script>
