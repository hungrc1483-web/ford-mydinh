<div id="partner-list">Đang kết nối hệ thống...</div>
</div>
<style type="text/css">/* Grid danh sách ngoài */
    .sale-grid { display: grid; gap: 15px 12px; grid-template-columns: repeat(6, 1fr); }
    @media (max-width: 1200px) { .sale-grid { grid-template-columns: repeat(4, 1fr); } }
    @media (max-width: 768px) { .sale-grid { grid-template-columns: repeat(3, 1fr); } }

    .sale-item { display: flex; align-items: center; cursor: pointer; padding: 5px 0; transition: 0.3s; }
    .sale-item:hover { transform: scale(1.05); }
    .sale-avatar { width: 55px; height: 55px; border-radius: 50%; object-fit: cover; margin-right: 12px; border: 1px solid #eee; }
    .sale-name { font-size: 1.1rem; font-weight: 800; color: #000; }
    .sale-agency { font-size: 0.8rem; color: #d32f2f; font-weight: 600; }

    /* VISIT CARD CAO CẤP */
    #webxeModal { 
        display: none; position: fixed; z-index: 10001; 
        left: 0; top: 0; width: 100%; height: 100%; 
        background: rgba(0,0,0,0.8); backdrop-filter: blur(8px);
    }
    
    .visit-card {
        background: #fff;
        margin: 12vh auto;
        width: 90%; max-width: 420px;
        border-radius: 25px;
        overflow: hidden;
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        position: relative;
        animation: cardFade 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }
    @keyframes cardFade { from {opacity: 0; transform: translateY(30px);} to {opacity: 1; transform: translateY(0);} }

    /* Họa tiết chìm và Header */
    .card-bg-pattern {
        position: absolute; top: 0; left: 0; width: 100%; height: 140px;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        z-index: 1;
    }
    .card-bg-pattern::after {
        content: ""; position: absolute; top: -50px; right: -50px;
        width: 150px; height: 150px; background: rgba(211, 47, 47, 0.05);
        border-radius: 50%;
    }

    .card-header-content {
        position: relative; z-index: 2; padding: 20px 25px;
        display: flex; justify-content: space-between; align-items: flex-start;
    }
    
    .card-agency-title { 
        font-size: 0.85rem; font-weight: 700; color: #555; 
        max-width: 70%; text-transform: uppercase; line-height: 1.3;
    }

    .card-logo-box img { max-height: 40px; max-width: 100px; object-fit: contain; }

    .card-body { position: relative; z-index: 3; padding: 0 30px 30px 30px; margin-top: -20px; }
    
    .avatar-wrapper { position: relative; display: inline-block; }
    .card-avatar-img {
        width: 120px; height: 120px; border-radius: 50%;
        border: 6px solid #fff; object-fit: cover;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

    .card-main-info { margin-top: 15px; text-align: left; }
    .card-sale-name { font-size: 1.8rem; font-weight: 900; color: #1a1a1a; line-height: 1; }
    .card-sale-rank { font-size: 1rem; color: #d32f2f; font-weight: 700; margin-bottom: 20px; }

    .card-contact-list { border-top: 1px solid #f0f0f0; padding-top: 20px; }
    .contact-item { display: flex; align-items: center; margin-bottom: 12px; font-size: 0.95rem; color: #444; }
    .contact-item b { width: 85px; color: #888; font-weight: 600; }
    .contact-item a { color: #d32f2f; text-decoration: none; font-weight: 700; }

    .btn-visit {
        display: block; width: 100%; padding: 16px; border-radius: 15px;
        background: linear-gradient(to right, #e53935, #d32f2f);
        color: #fff !important; text-align: center; font-weight: 800;
        text-decoration: none !important; text-transform: uppercase;
        margin-top: 20px; box-shadow: 0 8px 20px rgba(211, 47, 47, 0.3);
        transition: 0.3s;
    }
    .btn-visit:hover { transform: translateY(-3px); box-shadow: 0 12px 25px rgba(211, 47, 47, 0.4); }
</style>
<script>
(function() {
    const URL_API = "https://script.google.com/macros/s/AKfycbxCtkqD6xsLKjJh40rJ-xo0rRhQAlocl2L0nvHvJ3e-weFIRKSxJh3exQ-wvvo6PogZNA/exec";
    const BRAND_LOGOS = {
        "Vinfast": "https://upload.wikimedia.org/wikipedia/commons/thumb/d/d4/VinFast_logo.svg/1200px-VinFast_logo.svg.png",
        "Toyota": "https://upload.wikimedia.org/wikipedia/commons/thumb/9/9d/Toyota_car_logo.svg/1024px-Toyota_car_logo.svg.png",
        "Hyundai": "https://upload.wikimedia.org/wikipedia/commons/thumb/4/44/Hyundai_Motor_Company_logo.svg/2560px-Hyundai_Motor_Company_logo.svg.png",
        "Kia": "https://upload.wikimedia.org/wikipedia/commons/thumb/4/47/KIA_logo_2021.svg/2560px-KIA_logo_2021.svg.png",
        "Mazda": "https://upload.wikimedia.org/wikipedia/commons/thumb/a/ab/Mazda_logo_%282018%29.svg/2560px-Mazda_logo_%282018%29.svg.png",
        "Ford": "https://upload.wikimedia.org/wikipedia/commons/thumb/3/3e/Ford_logo.svg/2560px-Ford_logo.svg.png",
        "Mitsubishi": "https://upload.wikimedia.org/wikipedia/commons/thumb/5/5a/Mitsubishi_logo.svg/1200px-Mitsubishi_logo.svg.png",
        "Honda": "https://upload.wikimedia.org/wikipedia/commons/thumb/7/7b/Honda_Logo.svg/2560px-Honda_Logo.svg.png",
        "Mg": "https://upload.wikimedia.org/wikipedia/en/thumb/e/e0/MG_Motor_logo.svg/1200px-MG_Motor_logo.svg.png"
    };

    async function load() {
        const div = document.getElementById('partner-list');
        try {
            const res = await fetch(URL_API);
            const data = await res.json();
            if (!data) return;
            div.innerHTML = "";
            
            const uniqueBrands = [...new Set(data.map(item => item["Hãng"]))].filter(Boolean);
            uniqueBrands.forEach(brand => {
                const list = data.filter(s => s["Hãng"] === brand);
                let html = `<div style="margin-bottom:40px">
                    <div style="font-weight:900; color:#d32f2f; margin-bottom:15px; text-transform:uppercase; border-left:4px solid #d32f2f; padding-left:12px">| ${brand}</div>
                    <div class="sale-grid">`;
                list.forEach(item => {
                    const itemData = encodeURIComponent(JSON.stringify(item));
                    html += `
                        <div class="sale-item" onclick="viewCard('${itemData}')">
                            <img src="${item["Ảnh"] || 'https://via.placeholder.com/150'}" class="sale-avatar">
                            <div>
                                <div class="sale-name">${item["Tên"] || ""}</div>
                                <div class="sale-agency">${item["Đại lý"] || ""}</div>
                            </div>
                        </div>`;
                });
                html += `</div></div>`;
                div.innerHTML += html;
            });
        } catch (e) { console.error(e); }
    }

    window.viewCard = function(encoded) {
        const item = JSON.parse(decodeURIComponent(encoded));
        const logo = BRAND_LOGOS[item["Hãng"]] || "";
        const webLink = item["Website"] && item["Website"].startsWith('http') ? item["Website"] : `http://${item["Website"]}`;

        document.getElementById("webxeModal").style.display = "block";
        document.getElementById("modal-content").innerHTML = `
            <div class="visit-card">
                <div class="card-bg-pattern"></div>
                <div class="card-header-content">
                    <div class="card-agency-title">${item["Đại lý"] || ""}</div>
                    <div class="card-logo-box">
                        ${logo ? `<img src="${logo}" onerror="this.style.display='none'">` : ""}
                    </div>
                </div>
                <div class="card-body">
                    <div class="avatar-wrapper">
                        <img src="${item["Ảnh"] || 'https://via.placeholder.com/150'}" class="card-avatar-img">
                    </div>
                    <div class="card-main-info">
                        <div class="card-sale-name">${item["Tên"] || ""}</div>
                        <div class="card-sale-rank">Phụ trách kinh doanh</div>
                    </div>
                    <div class="card-contact-list">
                        <div class="contact-item"><b>Hotline:</b> <a href="tel:${item["Hotline"]}">${item["Hotline"] || ""}</a></div>
                        <div class="contact-item"><b>Khu vực:</b> <span>${item["Tỉnh"] || ""}</span></div>
                        <div class="contact-item"><b>Email:</b> <span style="font-size:0.85rem">${item["Email"] || ""}</span></div>
                    </div>
                    <a href="${webLink}" target="_blank" class="btn-visit">XEM TRANG CÁ NHÂN</a>
                </div>
                <span onclick="closeCard()" style="position:absolute; top:15px; right:20px; z-index:10; cursor:pointer; font-size:30px; color:#aaa;">×</span>
            </div>
        `;
    };

    window.closeCard = () => document.getElementById("webxeModal").style.display = "none";
    load();
})();
</script>
